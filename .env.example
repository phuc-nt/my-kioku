# OpenRouter credentials for the agent-simulation harness (tests/sim/).
# Copy to .env (which is gitignored) and fill in real values.
# Used ONLY by tests/sim/* to drive a small model through the SKILL.md protocol —
# the my-kioku CLI itself needs NO API key and makes NO network calls.

OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=qwen/qwen3.6-flash
OPENROUTER_REFERER=https://github.com/phuc-nt/my-kioku
OPENROUTER_TITLE=my-kioku-agent-sim
